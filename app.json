{
  "expo": {
    "name": "ThriBing",
    "slug": "thribing",
    "owner": "kobinggg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/all-logo.png",
    "scheme": "thribing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kobinggg.thribing"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/all-logo.png",
      "name": "ThriBing",
      "shortName": "ThriBing",
      "description": "Level up your life. Build habits, complete dailies, and grow your character.",
      "themeColor": "#8B5CF6",
      "backgroundColor": "#1A1A2E"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#8B5CF6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8597ee04-e0e7-46e8-b955-b0daaa0412b5"
      }
    }
  }
}
